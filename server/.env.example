# ================================================================
#  BELLA BRASIL MARKET PLUS — Variáveis de Ambiente
#  COMO USAR:
#  1. Copie este arquivo e renomeie para ".env"   (sem o .example)
#  2. Preencha os valores abaixo com os dados do Square
#  3. Para trocar de conta (ex: conta do seu chefe), apenas
#     troque os valores aqui e reinicie o servidor.
#
#  ⚠️  NUNCA compartilhe o arquivo .env — ele contém segredos!
#  ⚠️  O .env já está no .gitignore por segurança.
# ================================================================

# -----------------------------------
#  SQUARE — Credenciais da API
# -----------------------------------

# Seu token de acesso ao Square.
# Sandbox (para testes): começa com "EAAAl_..."
# Produção (conta real):  começa com "EAAAlxxx..."
SQUARE_ACCESS_TOKEN=EAAAl_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID da sua localização no Square Dashboard
# Encontre em: Square Dashboard → Conta → Localizações
SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX

# Ambiente: "sandbox" para testes, "production" para conta real
SQUARE_ENVIRONMENT=sandbox

# -----------------------------------
#  SERVIDOR
# -----------------------------------

# Porta onde o backend vai rodar (padrão: 3333)
PORT=3333

# URL do seu frontend (para CORS — quem pode chamar o backend)
# Em desenvolvimento local:
FRONTEND_URL=http://localhost:3001
# Em produção (Shopify/domínio real), troque para:
# FRONTEND_URL=https://seudominio.com
